# Required
ODOO_URL=https://example.odoo.com
ODOO_USERNAME=user@example.com

# API key (for XML-RPC): Settings → Technical → API Keys
ODOO_API_KEY=your_api_key_here

# Actual login password (for form/session auth — needed when DB name is unknown).
# Leave empty if ODOO_DB is set and XML-RPC/JSON-RPC auth works.
ODOO_PASSWORD=

# Optional - leave EMPTY to auto-detect
# For Odoo.com SaaS / Odoo.sh: if auto-detect fails, check Odoo.sh dashboard
# or ask your admin: psql -l  (lists PostgreSQL databases on the server)
ODOO_DB=
